{
    "name": "sayscript/server",
    "description": "SayScript local WebSocket server — real-time two-way sync of .user.js files with a Chromium extension.",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": ">=8.1",
        "cboden/ratchet": "^0.4.4"
    },
    "autoload": {
        "psr-4": {
            "SayScript\\": "src/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    }
}
